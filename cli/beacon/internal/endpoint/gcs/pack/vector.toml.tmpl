# Beacon Endpoint Agent -> Google Cloud Storage
#
# Run Vector as a customer-managed host agent. Keep Google credentials,
# service-account bindings, workload identity, bucket IAM, lifecycle, retention,
# and encryption in Google Cloud or deployment tooling, not in Beacon config.
# This template relies on Google Application Default Credentials.

data_dir = "/var/lib/vector/beacon-gcs"

[sources.beacon_runtime]
type = "file"
include = ["{{LOG_PATH}}"]
read_from = "end"

[transforms.beacon_json]
type = "remap"
inputs = ["beacon_runtime"]
source = '''
. = parse_json!(.message)
'''

[sinks.beacon_gcs]
type = "gcp_cloud_storage"
inputs = ["beacon_json"]
bucket = "${BEACON_GCS_BUCKET}"
key_prefix = "${BEACON_GCS_PREFIX:-beacon/runtime}/date=%F/"
filename_time_format = "%s"
filename_append_uuid = true
filename_extension = "jsonl.gz"
compression = "gzip"
content_encoding = "gzip"
content_type = "application/x-ndjson"
storage_class = "${BEACON_GCS_STORAGE_CLASS:-STANDARD}"

[sinks.beacon_gcs.encoding]
codec = "json"

[sinks.beacon_gcs.framing]
method = "newline_delimited"

[sinks.beacon_gcs.batch]
max_bytes = 10000000
timeout_secs = 300

[sinks.beacon_gcs.request]
retry_attempts = 10
retry_initial_backoff_secs = 1
retry_max_duration_secs = 300
