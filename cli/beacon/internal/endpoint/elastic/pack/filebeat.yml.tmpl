filebeat.inputs:
  - type: filestream
    id: beacon-endpoint
    enabled: true
    paths:
      - "{{LOG_PATH}}"
    parsers:
      - ndjson:
          keys_under_root: true
          add_error_key: true
          overwrite_keys: true
    fields_under_root: true
    fields:
      data_stream.type: logs
      data_stream.dataset: beacon.endpoint
      data_stream.namespace: default

output.elasticsearch:
  hosts: ["${ES_HOSTS:http://localhost:9200}"]
  ssl.verification_mode: "${ES_SSL_VERIFY:full}"
  index: "logs-beacon.endpoint-default"
  # For hosted or secured clusters, configure one auth method:
  # api_key: "${ES_API_KEY}"
  # username: "${ES_USERNAME}"
  # password: "${ES_PASSWORD}"

setup.template.enabled: false
setup.ilm.enabled: false
